replace_once(
    'src/ui/tabs.rs',
    '''                    let current_tab_num =\n                        tab_num_for_widget(&root_for_exit).unwrap_or(tab_num_for_exit);\n                    let is_split = root_for_exit\n''',
    '''                    let current_tab_num =\n                        tab_num_for_widget(&root_for_exit).unwrap_or(tab_num_for_exit);\n                    if !ui_for_exit.pane_root_is_attached(&root_for_exit) {\n                        return;\n                    }\n                    let is_split = root_for_exit\n''',
)
# There are two identical callback fragments; replace the second one separately.
text = Path('src/ui/tabs.rs').read_text(encoding='utf-8')
needle = '''                    let current_tab_num =\n                        tab_num_for_widget(&root_for_exit).unwrap_or(tab_num_for_exit);\n                    let is_split = root_for_exit\n'''
if text.count(needle) != 1:
    raise SystemExit(f'src/ui/tabs.rs: expected remaining VTE exit callback once, found {text.count(needle)}')
Path('src/ui/tabs.rs').write_text(
    text.replace(
        needle,
        '''                    let current_tab_num =\n                        tab_num_for_widget(&root_for_exit).unwrap_or(tab_num_for_exit);\n                    if !ui_for_exit.pane_root_is_attached(&root_for_exit) {\n                        return;\n                    }\n                    let is_split = root_for_exit\n''',
        1,
    ),
    encoding='utf-8',
)

