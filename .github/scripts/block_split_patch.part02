replace_once(
    'src/ui/session.rs',
    '''    fn first_saved_leaf(\n        layout: &crate::state::PaneLayout,\n    ) -> (&str, &str, &Option<String>, Option<bool>) {\n        match layout {\n            crate::state::PaneLayout::Leaf {\n                dir,\n                sid,\n                cmds,\n                pinned,\n            } => (dir, sid, cmds, *pinned),\n            crate::state::PaneLayout::Split { start, .. } => Self::first_saved_leaf(start),\n        }\n    }\n''',
    '''    fn first_saved_leaf(\n        layout: &crate::state::PaneLayout,\n    ) -> (\n        String,\n        String,\n        Option<String>,\n        Option<bool>,\n        Option<PaneBackend>,\n        Option<String>,\n    ) {\n        match layout {\n            crate::state::PaneLayout::Leaf {\n                dir,\n                sid,\n                cmds,\n                pinned,\n                backend,\n                history_path,\n            } => (\n                dir.clone(),\n                sid.clone(),\n                cmds.clone(),\n                *pinned,\n                *backend,\n                history_path.clone(),\n            ),\n            crate::state::PaneLayout::Split { start, .. } => Self::first_saved_leaf(start),\n        }\n    }\n''',
)
replace_once(
    'src/ui/session.rs',
    '''            PaneLayout::Leaf {\n                dir,\n                sid,\n                cmds,\n                pinned,\n            } => {\n                let root = if let Some(existing) = first_leaf.take() {\n                    existing\n                } else {\n                    self.create_vte_leaf(Some(&dir), Some(&sid), cmds.as_deref(), tab_widget_name)\n                        .root_widget()\n                };\n''',
    '''            PaneLayout::Leaf {\n                dir,\n                sid,\n                cmds,\n                pinned,\n                backend,\n                history_path,\n            } => {\n                let root = if let Some(existing) = first_leaf.take() {\n                    existing\n                } else {\n                    match backend.unwrap_or(PaneBackend::Vte) {\n                        PaneBackend::Block => {\n                            let configured = self.config.borrow().block_history_path.clone();\n                            let history_path = history_path.or_else(|| {\n                                crate::state::block_history_path_for_pane(\n                                    configured.as_deref(),\n                                    &sid,\n                                )\n                            });\n                            self.create_block_leaf(\n                                Some(&dir),\n                                Some(&sid),\n                                cmds.as_deref(),\n                                history_path.as_deref(),\n                                tab_widget_name,\n                            )\n                            .root_widget()\n                        }\n                        PaneBackend::Vte => self\n                            .create_vte_leaf(\n                                Some(&dir),\n                                Some(&sid),\n                                cmds.as_deref(),\n                                tab_widget_name,\n                            )\n                            .root_widget(),\n                    }\n                };\n''',
