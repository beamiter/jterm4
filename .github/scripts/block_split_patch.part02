    '''            PaneLayout::Leaf {\n                dir,\n                sid,\n                cmds,\n                pinned,\n            } => {\n                // Create a simple tab with the leaf layout\n                let _terminal = self.add_new_tab(Some(dir), tab_name, Some(sid), cmds);\n''',
    '''            PaneLayout::Leaf {\n                dir,\n                sid,\n                cmds,\n                pinned,\n                backend,\n                history_path,\n            } => {\n                let terminal_mode = match backend {\n                    Some(PaneBackend::Block) => crate::config::TerminalMode::Block,\n                    Some(PaneBackend::Vte) => crate::config::TerminalMode::Vte,\n                    None => self.config.borrow().terminal_mode.clone(),\n                };\n                let _terminal = self.add_restored_tab(\n                    Some(dir),\n                    tab_name,\n                    Some(sid),\n                    cmds,\n                    terminal_mode,\n                    history_path,\n                );\n''',
