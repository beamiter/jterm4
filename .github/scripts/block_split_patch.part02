    '''        let (dir, sid, cmds, pinned) = Self::first_saved_leaf(&layout);\n        self.add_new_tab(\n            Some(dir.to_string()),\n            tab_name,\n            Some(sid.to_string()),\n            cmds.clone(),\n        );\n''',
    '''        let (dir, sid, cmds, pinned, backend, history_path) =\n            Self::first_saved_leaf(&layout);\n        let terminal_mode = match backend {\n            Some(PaneBackend::Block) => crate::config::TerminalMode::Block,\n            Some(PaneBackend::Vte) => crate::config::TerminalMode::Vte,\n            None => self.config.borrow().terminal_mode.clone(),\n        };\n        self.add_restored_tab(\n            Some(dir),\n            tab_name,\n            Some(sid),\n            cmds,\n            terminal_mode,\n            history_path,\n        );\n''',
