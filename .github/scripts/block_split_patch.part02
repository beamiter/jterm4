    '''    pub(crate) fn restore_pane_layout(\n        &self,\n        mut layout: crate::state::PaneLayout,\n        tab_name: Option<String>,\n    ) -> gtk4::Widget {\n        use crate::state::PaneLayout;\n\n        crate::state::normalize_pane_layout(&mut layout);\n        match layout {\n''',
