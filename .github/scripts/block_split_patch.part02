insert_before_once(
    'src/ui/panes.rs',
    '''    pub(crate) fn split_current(&self, orientation: Orientation) {\n''',
    '''    pub(crate) fn pane_root_is_attached(&self, root: &gtk4::Widget) -> bool {\n        root.parent().is_some()\n            || self.notebook.page_num(root).is_some()\n            || PaneLeaf::from_widget(root).is_some_and(|leaf| {\n                self.zoom_state\n                    .borrow()\n                    .as_ref()\n                    .is_some_and(|state| state.zoomed_terminal == *leaf.terminal())\n            })\n    }\n\n    /// Create a Block leaf with its own TermView, PTY, reader lifecycle, history\n    /// identity, selection/search model, and process cleanup path.\n    pub(crate) fn create_block_leaf(\n        &self,\n        working_directory: Option<&str>,\n        session_id: Option<&str>,\n        initial_commands: Option<&str>,\n        history_path: Option<&str>,\n        tab_widget_name: Option<String>,\n    ) -> PaneLeaf {\n        let sid = session_id\n            .map(str::to_owned)\n            .unwrap_or_else(generate_session_id);\n        let mut config = self.config.borrow().clone();\n        config.block_history_path = history_path.map(str::to_owned);\n        let shell_argv = self.shell_argv.borrow();\n        let view = Rc::new(TermView::new(\n            &config,\n            shell_argv.as_slice(),\n            working_directory,\n            Some(&sid),\n            initial_commands,\n        ));\n        drop(shell_argv);\n\n        let terminal = view.vte().clone();\n        setup_terminal_click_handler(&terminal);\n        self.setup_context_menu(&terminal);\n\n        let leaf = PaneLeaf::Block(view.clone());\n        let root = leaf.root_widget();\n        if let Some(name) = tab_widget_name.as_deref() {\n            root.set_widget_name(name);\n        }\n        leaf.attach_to(&root);\n        leaf.set_session_id(&sid);\n        leaf.set_remote(false);\n\n        let ui_for_exit = self.clone();\n        let root_for_exit = root.clone();\n        let view_for_exit = Rc::downgrade(&view);\n        view.connect_exited(move |_| {\n            if let Some(view) = view_for_exit.upgrade() {\n                let _ = view.save_history();\n            }\n            if ui_for_exit.pane_root_is_attached(&root_for_exit) {\n                ui_for_exit.handle_terminal_exited(&root_for_exit);\n            }\n        });\n\n        let config_for_history = self.config.clone();\n        let view_for_history = Rc::downgrade(&view);\n        view.connect_block_finished(move |command, exit_code, _output_sample| {\n            let config = config_for_history.borrow();\n            if !config.command_history_enabled {\n                return;\n            }\n            let Some(path) = config.command_history_path.as_deref() else {\n                return;\n            };\n            let cwd = view_for_history\n                .upgrade()\n                .map(|view| view.cwd())\n                .filter(|cwd| !cwd.is_empty());\n            let end_time_ms = std::time::SystemTime::now()\n                .duration_since(std::time::UNIX_EPOCH)\n                .ok()\n                .and_then(|duration| u64::try_from(duration.as_millis()).ok());\n            if let Err(error) = crate::command_history::append(\n                std::path::Path::new(path),\n                config.command_history_max_entries as usize,\n                &command,\n                cwd.as_deref(),\n                exit_code,\n                end_time_ms,\n            ) {\n                log::warn!("failed to append command history: {error}");\n            }\n        });\n\n        if tab_widget_name.is_some() {\n            let ui_for_bell = self.clone();\n            let leaf_for_bell = leaf.clone();\n            view.connect_bell(move || {\n                ui_for_bell.mark_tab_bell(&leaf_for_bell.root_widget().widget_name());\n            });\n\n            let ui_for_activity = self.clone();\n            let leaf_for_activity = leaf.clone();\n            view.connect_activity(move || {\n                ui_for_activity.mark_tab_activity(&leaf_for_activity.root_widget().widget_name());\n            });\n        }\n\n        leaf\n    }\n\n''',
)
replace_once(
    'src/ui/panes.rs',
    '''        let current_term = current_leaf.terminal().clone();\n        let working_directory = terminal_working_directory(&current_term);\n        let tab_widget_name = Some(page_widget.widget_name().to_string());\n        let current_widget = current_leaf.root_widget();\n        let parent = current_widget.parent();\n\n        let new_leaf =\n            self.create_vte_leaf(working_directory.as_deref(), None, None, tab_widget_name);\n''',
    '''        let current_term = current_leaf.terminal().clone();\n        let working_directory = if current_leaf.is_remote() {\n            None\n        } else {\n            current_leaf\n                .block_view()\n                .map(|view| view.cwd())\n                .filter(|cwd| !cwd.is_empty())\n                .or_else(|| terminal_working_directory(&current_term))\n        };\n        let tab_widget_name = Some(page_widget.widget_name().to_string());\n        let current_widget = current_leaf.root_widget();\n        let parent = current_widget.parent();\n        let new_session_id = generate_session_id();\n\n        let new_leaf = if current_leaf.is_block() {\n            let configured_history = self.config.borrow().block_history_path.clone();\n            let history_path = block_history_path_for_pane(\n                configured_history.as_deref(),\n                &new_session_id,\n            );\n            self.create_block_leaf(\n                working_directory.as_deref(),\n                Some(&new_session_id),\n                None,\n                history_path.as_deref(),\n                tab_widget_name,\n            )\n        } else {\n            self.create_vte_leaf(\n                working_directory.as_deref(),\n                Some(&new_session_id),\n                None,\n                tab_widget_name,\n            )\n        };\n''',
)
# Make the conventional split exit callback attachment-aware too.
replace_once(
    'src/ui/panes.rs',
    '''        let ui_for_exit = UiState::clone(self);\n        let terminal_for_exit = terminal.clone();\n        view.connect_exited(move |_| {\n            ui_for_exit.handle_terminal_exited(&terminal_for_exit.clone().upcast::<gtk4::Widget>());\n        });\n\n        let leaf = PaneLeaf::Vte(view);\n''',
    '''        let leaf = PaneLeaf::Vte(view.clone());\n        let root_for_exit = leaf.root_widget();\n        let ui_for_exit = UiState::clone(self);\n        view.connect_exited(move |_| {\n            if ui_for_exit.pane_root_is_attached(&root_for_exit) {\n                ui_for_exit.handle_terminal_exited(&root_for_exit);\n            }\n        });\n\n''',
)
# Keep split leaf metadata routed to the owning tab while session identity remains per leaf.
replace_once(
    'src/ui/panes.rs',
    '''        let root = leaf.root_widget();\n        leaf.attach_to(&root);\n''',
    '''        let root = leaf.root_widget();\n        if let Some(name) = tab_widget_name.as_deref() {\n            root.set_widget_name(name);\n        }\n        leaf.attach_to(&root);\n''',
)

