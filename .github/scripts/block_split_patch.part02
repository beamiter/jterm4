# Idempotent PTY process-group cleanup; natural exit and explicit close share one claim.
replace_once(
    'src/pty.rs',
    '''    shell_bracketed_paste: Arc<AtomicBool>,\n}\n''',
    '''    shell_bracketed_paste: Arc<AtomicBool>,\n    /// Shared with the reader so natural exit, pane close, tab close, window close,\n    /// and Drop can claim process-group termination at most once.\n    terminated: Arc<AtomicBool>,\n}\n''',
)
insert_before_once(
    'src/pty.rs',
    '''impl OwnedPty {\n''',
    '''fn claim_termination(terminated: &AtomicBool) -> bool {\n    !terminated.swap(true, Ordering::AcqRel)\n}\n\n''',
)
replace_once(
    'src/pty.rs',
    '''                    shell_bracketed_paste: Arc::new(AtomicBool::new(false)),\n                })\n''',
    '''                    shell_bracketed_paste: Arc::new(AtomicBool::new(false)),\n                    terminated: Arc::new(AtomicBool::new(false)),\n                })\n''',
)
replace_once(
    'src/pty.rs',
    '''    pub fn kill(&self) {\n        self.close_master_fd();\n        terminate_terminal_process(self.pid.as_raw());\n    }\n''',
