# jterm4 配置文件示例
# 将此文件复制到 ~/.config/jterm4/config.toml 并根据需要修改

# ============================================================================
# 基础设置
# ============================================================================

# 终端模式: "block" 或 "vte"
# - block: 块模式，命令历史以块形式显示（推荐）
# - vte: 传统终端模式
terminal_mode = "block"

# 窗口透明度 (0.0 - 1.0)
# 0.0 = 完全透明，1.0 = 完全不透明
opacity = 0.95

# 回滚缓冲区行数
# 保存的历史输出行数
scrollback = 5000

# 字体
# 使用 Nerd Font 以获得最佳图标支持
font = "SauceCodePro Nerd Font Regular 14"

# 字体缩放
# 1.0 = 正常大小，可以通过 Ctrl+Plus/Minus 动态调整
font_scale = 1.0

# 主题
# 可选: "default", "light", 或其他内置主题
theme = "default"

# ============================================================================
# 启动命令（可选）
# ============================================================================

# 新终端启动时自动执行的命令（逗号分隔）
# 例如: "cd ~/projects, nix develop"
# startup_commands = "cd ~/projects"

# ============================================================================
# 块模式优化（仅在 terminal_mode = "block" 时生效）
# ============================================================================

# ANSI 缓存容量
# 缓存 ANSI 转换结果以提高性能
ansi_cache_capacity = 1000

# 最大可见块数
# 限制同时显示的命令块数量以提高性能
max_visible_blocks = 100

# 输出批处理时间（毫秒）
# 最小批处理延迟
output_batch_min_ms = 8

# 最大批处理延迟
output_batch_max_ms = 32

# 虚拟滚动边距
virtual_scroll_margin = 5

# ============================================================================
# 块历史（实验性）
# ============================================================================

# 块历史保存路径（可选）
# block_history_path = "~/.local/share/jterm4/block_history"

# 是否压缩块历史
block_history_compress = true

# ============================================================================
# 快捷键配置
# ============================================================================

# 快捷键在 ~/.claude/keybindings.json 中配置
# 运行 jterm4 后按 Ctrl+Shift+K 查看所有快捷键

# ============================================================================
# 常用快捷键
# ============================================================================

# Tab 管理:
#   Ctrl+Shift+T    - 新建 Tab
#   Ctrl+Shift+W    - 关闭当前 Tab
#   Ctrl+Tab        - 下一个 Tab
#   Ctrl+Shift+Tab  - 上一个 Tab
#   Alt+1-9         - 快速切换到 Tab 1-9

# 分屏:
#   Ctrl+Shift+\    - 水平分屏
#   Ctrl+Shift+|    - 垂直分屏
#   Alt+方向键      - 切换焦点到不同的窗格
#   Alt+Shift+方向键 - 调整窗格大小
#   Ctrl+Shift+Z    - 最大化/恢复当前窗格

# 其他:
#   Ctrl+Shift+C    - 复制
#   Ctrl+Shift+V    - 粘贴
#   Ctrl+Shift+F    - 搜索
#   Ctrl+Plus       - 放大字体
#   Ctrl+Minus      - 缩小字体
#   Ctrl+Shift+R    - 重载配置

# ============================================================================
# 高级配置
# ============================================================================

# 如需更高级的配置，请参考:
# https://github.com/your-repo/jterm4/blob/master/docs/configuration.md
